{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "paths": { "@omega/sdk": ["../../packages/sdk/src"] }
  },
  "include": ["src/renderer/**/*", "src/shared/**/*", "src/native-bridge/**/*"]
}
